# Copy to `.env.development` or `.env.local` and adjust.

# Dev server proxies /api and /socket.io to this URL (must match backend PORT).
# Use 127.0.0.1 instead of localhost on Windows to avoid IPv6 (::1) proxy errors (ECONNRESET).
# VITE_API_PROXY_TARGET=http://127.0.0.1:5001

# Optional: bypass proxy and call API directly (e.g. production build against local API).
# VITE_API_BASE_URL=http://127.0.0.1:5001/api

# Optional: Socket.io base URL (defaults to same origin; use for split deployments).
# VITE_SOCKET_URL=http://127.0.0.1:5001
