# Copy to `.env.test` and use a dedicated PostgreSQL database (not production).
NODE_ENV=test
PORT=5002

DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_surveillance_test
DB_USER=your_test_user
DB_PASSWORD=your_test_password

JWT_SECRET=test_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# Smaller pool is enough for Jest workers
DB_POOL_MAX=5
DB_POOL_MIN=0
