NODE_ENV=development
PORT=5001

# Testing: copy backend/.env.test.example to backend/.env.test (gitignored) and use a separate DB.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Database pool (for 400+ hotels scale)
# Total connections = DB_POOL_MAX per process.
# If running 2 PM2 workers, set DB_POOL_MAX=20 so total = 40 (stay under postgres max_connections).
DB_POOL_MAX=40
DB_POOL_MIN=2

# Socket.io (browser clients); use your frontend origin in production
# SOCKET_CORS_ORIGIN=http://localhost:3000
